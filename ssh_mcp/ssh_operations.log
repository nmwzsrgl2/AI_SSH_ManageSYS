#!/bin/bash
# 连接到服务器获取Zabbix server日志
ssh -p 22 -l readuser 10.0.147.10 "cat /var/log/zabbix/zabbix_server.log" > /tmp/zabbix_server.log

# 检查日志中关键错误和警告
grep -iE "error|warning|failed|timeout" /tmp/zabbix_server.log | awk '{print $0}' > /tmp/error_warnings.log

# 分析数据库连接问题（常见问题）
grep -iE "db.*connection|db.*timeout" /tmp/zabbix_server.log | awk '{print $0}' > /tmp/db_errors.log

# 检查性能指标异常（如CPU、内存）
grep -iE "CPU|memory|load|active" /tmp/zabbix_server.log | awk '{print $0}' > /tmp/performance.log

# 输出分析结果
echo "Zabbix server日志分析报告" > /tmp/report.txt
echo "错误/警告信息" >> /tmp/report.txt
cat /tmp/error_warnings.log >> /tmp/report.txt
echo "" >> /tmp/report.txt
echo "数据库连接错误" >> /tmp/report.txt
cat /tmp/db_errors.log >> /tmp/report.txt
echo "" >> /tmp/report.txt
echo "性能指标异常" >> /tmp/report.txt
cat /tmp/performance.log >> /tmp/report.txt

# 返回本地目录
cd /tmp

EOF
